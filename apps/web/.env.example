# Environment Variables for SQ Agriculture
# Copy this to .env and fill in your values

# App URL (Vercel URL after deploy)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Node Environment
NODE_ENV="development"

# Google Analytics 4 (Get from analytics.google.com)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry Error Tracking (Get from sentry.io)
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_SENTRY_DSN@o123456.ingest.sentry.io/1234567"