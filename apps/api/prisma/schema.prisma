// SQ Agriculture - Database Schema
// Prisma ORM with MySQL/PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  nameBn        String?
  phone         String?
  role          String    @default("PAGE_EDITOR") // SUPER_ADMIN, PAGE_EDITOR
  assignedPages String    @default("[]") // JSON array of page names user can edit (for PAGE_EDITOR)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  leads                  Lead[]   @relation("AssignedLeads")
  inquiries              Inquiry[] @relation("AssignedInquiries")
  wishlistItems          WishlistItem[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens          RefreshToken[]
  
  // Audit Trail Relations
  createdProducts Product[] @relation("CreatedProducts")
  updatedProducts Product[] @relation("UpdatedProducts")
  deletedProducts Product[] @relation("DeletedProducts")
  activityLogs    ActivityLog[]
  pageConfigs     PageConfig[]

  @@map("users")
}

model Category {
  id             String   @id @default(uuid())
  name           String
  nameBn         String?
  slug           String   @unique
  description    String?
  descriptionBn  String?
  image          String?
  type           String
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]

  @@index([type])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid())
  name           String
  nameBn         String?
  slug           String   @unique
  description    String
  descriptionBn  String?
  price          Float?
  priceUnit      String?
  images         String   @default("[]")
  brochure       String?
  specs          String   @default("{}")
  featured       Boolean  @default(false)
  inStock        Boolean  @default(true)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Pre-Owned Machine Details
  isPreOwned       Boolean  @default(false)
  preOwnedDetails  String?  // JSON: { year, hours, condition, previousOwner }
  
  // Inquire Only - Hide price and show contact details instead
  hidePrice       Boolean  @default(false)
  contactEmail    String?
  contactPhone   String?
  contactWhatsApp String?
  
  // Audit Trail
  createdById   String?
  createdBy     User?   @relation("CreatedProducts", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?   @relation("UpdatedProducts", fields: [updatedById], references: [id])
  deletedById   String?
  deletedBy     User?   @relation("DeletedProducts", fields: [deletedById], references: [id])
  deletedAt     DateTime?

  wishlistItems WishlistItem[]
  productLocations ProductLocation[]
  
  @@index([categoryId])
  @@index([featured])
  @@index([isActive])
  @@index([isPreOwned])
  @@index([hidePrice])
  @@map("products")
}

model Dealer {
  id          String   @id @default(uuid())
  name        String
  nameBn      String?
  phone       String
  email       String
  address     String
  district    String
  division    String
  latitude    Float?
  longitude   Float?
  image       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  productLocations ProductLocation[]

  @@index([division])
  @@index([district])
  @@index([isActive])
  @@map("dealers")
}

model ProductLocation {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([productId, dealerId])
  @@index([productId])
  @@index([dealerId])
  @@map("product_locations")
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  titleBn     String?
  slug        String   @unique
  excerpt     String
  excerptBn   String?
  content     String
  contentBn   String?
  image       String?
  author      String
  authorImage String?
  category    String
  tags        String   @default("[]")
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([category])
  @@map("blog_posts")
}

model Lead {
  id               String   @id @default(uuid())
  name             String
  email            String
  phone            String
  company          String?
  userType         String
  productInterest  String?
  message          String
  status           String   @default("NEW")
  notes            String?
  assignedToId     String?
  assignedTo       User?    @relation("AssignedLeads", fields: [assignedToId], references: [id])
  source           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@map("leads")
}

model Inquiry {
  id               String   @id @default(uuid())
  name             String
  email            String
  phone            String
  company          String?
  userType         String
  productInterest  String?
  message          String
  status           String   @default("NEW")
  notes            String?
  assignedToId     String?
  assignedTo       User?    @relation("AssignedInquiries", fields: [assignedToId], references: [id])
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@map("inquiries")
}

model NewsletterSubscription {
  id            String    @id @default(uuid())
  email         String    @unique
  isActive      Boolean   @default(true)
  subscribedAt  DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("newsletter_subscriptions")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model Upload {
  id            String   @id @default(uuid())
  filename      String
  originalName  String
  mimeType      String
  size          Int
  url           String
  entityType    String?
  entityId      String?
  uploadedById   String?
  createdAt     DateTime @default(now())

  @@map("uploads")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   // CREATE, UPDATE, DELETE, VIEW, LOGIN, LOGOUT, STATUS_CHANGE
  entityType  String   // Product, Category, User, Lead, Inquiry, Dealer, BlogPost
  entityId    String?
  entityName  String?  // Product name, User email, etc. for quick reference
  description String?   // Human-readable description
  oldValue   String?   // JSON string of old values
  newValue   String?   // JSON string of new values
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([timestamp])
  @@map("activity_logs")
}

model HomepageConfig {
  id                  String   @id @default(uuid())
  
  heroTitle            String?
  heroSubtitle        String?
  heroSlides         String   @default("[]")
  heroUseCategories Boolean  @default(false)
  
  sliderCategories   String   @default("[]")
  
  features          String   @default("[]")
  
  videoEnabled      Boolean  @default(true)
  videoTitle       String?
  videoSubtitle   String?
  videoPlaylistId String?
  videoUrls       String   @default("[]")
  
  stats           String   @default("[]")
  
  ctaTitle        String?
  ctaSubtitle    String?
  ctaButtonText  String?
  ctaButtonLink  String?
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@map("homepage_configs")
}

// Page configurations for each category
model PageConfig {
  id           String   @id @default(cuid())
  pageName     String   @unique // seeds, pesticides, fertilizers, machinery, gallery, homepage
  heroTitle    String?
  heroSubtitle String?
  heroImage    String?
  features     String   @default("[]") // Array of page-specific features
  customConfig String   @default("{}") // Page-specific settings
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])

  @@map("page_configs")
}

// Floating button settings
model FloatingButtonSettings {
  id           String   @id @default(cuid())
  whatsapp     String?  // WhatsApp number or link
  facebook     String?  // Facebook page URL
  email        String?  // Email address
  isEnabled    Boolean  @default(true)
  showWhatsapp Boolean  @default(true)
  showFacebook Boolean  @default(true)
  showEmail    Boolean  @default(true)
  position     String   @default("bottom-right") // bottom-right, bottom-left
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("floating_button_settings")
}

model SeedPartner {
  id          String   @id @default(cuid())
  name       String
  nameBn     String?
  logo       String?  // Logo image URL
  description String?
  website    String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("seed_partners")
}

// Service 24X7 Settings - Service & Spare Parts page content
model ServiceSettings {
  id           String   @id @default(cuid())
  
  // Contact Info
  hotlinePhone String?
  whatsapp     String?
  email        String?
  isActive     Boolean  @default(true)
  
  // Hero Section
  heroTitle       String?
  heroTitleBn     String?
  heroSubtitle    String?
  heroSubtitleBn  String?
  
  // SQ Lubricants Section
  lubricantsTitle       String?
  lubricantsTitleBn     String?
  lubricantsDescription String?
  lubricantsDescriptionBn String?
  lubricantsEnabled     Boolean  @default(true)
  
  // Spare Parts Section
  sparePartsTitle       String?
  sparePartsTitleBn     String?
  sparePartsDescription String?
  sparePartsDescriptionBn String?
  sparePartsEnabled     Boolean  @default(true)
  
  // Service 24X7 Section
  serviceTitle       String?
  serviceTitleBn     String?
  serviceDescription String?
  serviceDescriptionBn String?
  serviceEnabled     Boolean  @default(true)
  
  // JSON Fields
  serviceFeatures String @default("[]")  
  serviceCenters  String @default("[]")  
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("service_settings")
}
